#!/usr/bin/env bash
# platform-gitops/deploy -- pin a site's dev overlay to an ECR image tag and
# protect that image from lifecycle expiry.
#
# Usage:
#   ./deploy <site> [<sha>] [--prod]
#     site   : patrickdwyer-com | cwdmdc | draw
#     sha    : optional build tag; if omitted, pick from a menu of recent builds
#              shown as their commit messages.
#     --prod : target the prod overlay. Dev is the default and stays the default:
#              a production deploy should be something you asked for explicitly,
#              never something you get by forgetting an argument.
#
# Runs under Patrick's local AWS creds (aws-switch-personal). Uses aws + git only.
set -euo pipefail

REGION=us-east-2
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() { echo "usage: ./deploy <patrickdwyer-com|cwdmdc|draw> [<sha>] [--prod]" >&2; exit 2; }

site_ecr_repo() { case "$1" in
  patrickdwyer-com) echo patrickdwyer-com ;;
  cwdmdc)           echo cwdmdc ;;
  draw)             echo draw ;;
  *) return 1 ;; esac; }

site_overlay() { echo "$REPO_ROOT/workloads/$1/overlays/$2/kustomization.yaml"; }

site_src() { case "$1" in
  patrickdwyer-com) echo "$HOME/dev/athens/sites/patrickdwyer.com" ;;
  cwdmdc)           echo "$HOME/dev/athens/sites/cwdmdc.patrickdwyer.com" ;;
  draw)             echo "$HOME/dev/draw.patrickdwyer.com" ;;
  *) return 1 ;; esac; }

# Rewrite the single `newTag:` line. Pure + testable. Portable across BSD (macOS)
# and GNU sed via a temp file rather than sed -i. `|` delimiter is safe (SHAs and
# URIs contain no `|`).
bump_tag() {
  local file="$1" new="$2" tmp
  tmp="$(mktemp)"
  # QUOTE the tag. An all-digit short SHA (e.g. 0089514) is otherwise parsed as a
  # YAML number, and kustomize rejects a non-string newTag ("cannot unmarshal
  # number into ... newTag of type string") -> Argo can't render -> silent no-deploy.
  sed "s|^\([[:space:]]*newTag:[[:space:]]*\).*|\1\"${new}\"|" "$file" > "$tmp"
  mv "$tmp" "$file"
}

# Add the deployed-<env>-<sha> protective alias to an existing image, unless it already
# exists (IMMUTABLE repos reject re-adding a tag). The env in the tag matters: the ECR
# lifecycle policy keeps a SEPARATE count budget per env (deployed-prod-* vs deployed-dev-*)
# so dev churn can never expire a prod pin. Registry-side manifest copy -- no docker, no pull.
protect_image() {
  local repo="$1" sha="$2" env="$3" tag="deployed-${env}-${sha}" manifest
  if aws ecr describe-images --repository-name "$repo" --region "$REGION" \
       --image-ids imageTag="$tag" >/dev/null 2>&1; then
    echo "  already protected: $tag"; return 0
  fi
  manifest="$(aws ecr batch-get-image --repository-name "$repo" --region "$REGION" \
    --image-ids imageTag="$sha" \
    --accepted-media-types \
      "application/vnd.docker.distribution.manifest.v2+json" \
      "application/vnd.oci.image.manifest.v1+json" \
    --query 'images[0].imageManifest' --output text)"
  aws ecr put-image --repository-name "$repo" --region "$REGION" \
    --image-tag "$tag" --image-manifest "$manifest" >/dev/null
  echo "  protected: $tag"
}

# Classify a failed `aws ecr describe-images` from its stderr text. Pure and
# testable: keeps the "is this really a missing tag?" decision out of the call
# site. describe-images exits nonzero both when the tag is absent AND when the
# call never ran (expired creds, wrong region, no network) — collapsing those
# into "tag not found" has twice sent us debugging a deploy that was really an
# auth failure.
classify_ecr_error() {
  case "$1" in
    *ImageNotFoundException*) echo notfound ;;
    *)                        echo other ;;
  esac
}

# Recent build tags, newest first, excluding deployed-* aliases and untagged.
recent_tags() {
  aws ecr describe-images --repository-name "$1" --region "$REGION" \
    --query 'reverse(sort_by(imageDetails,&imagePushedAt))[].imageTags' \
    --output text 2>/dev/null \
    | tr '\t' '\n' | grep -vE '^(deployed-|None$)' | grep -v '^$' | head -20
}

main() {
  local site="" sha="" env="dev" arg
  for arg in "$@"; do
    case "$arg" in
      --prod) env="prod" ;;
      --dev)  env="dev" ;;
      -*)     echo "unknown flag: $arg" >&2; usage ;;
      *)      if [ -z "$site" ]; then site="$arg"; elif [ -z "$sha" ]; then sha="$arg"; else usage; fi ;;
    esac
  done
  [ -n "$site" ] || usage
  local repo overlay src
  repo="$(site_ecr_repo "$site")" || { echo "unknown site: $site" >&2; usage; }
  overlay="$(site_overlay "$site" "$env")"
  src="$(site_src "$site")"
  [ -f "$overlay" ] || { echo "overlay not found: $overlay" >&2; exit 1; }

  # Preflight the credentials ONCE, up front. Without this an expired session
  # resurfaces downstream disguised — as "tag not found" at the existence check,
  # or as an empty build menu — and you debug the wrong thing. Fail here, clearly.
  local ident
  if ! ident="$(aws sts get-caller-identity --query Arn --output text 2>&1)"; then
    echo "AWS credentials are not usable — this is NOT a deploy problem:" >&2
    printf '  %s\n' "$ident" >&2
    echo "Re-authenticate (e.g. aws login --profile personal && aws-switch-personal) and retry." >&2
    exit 1
  fi

  if [ -z "$sha" ]; then
    local tags=() t i=1
    while IFS= read -r t; do tags+=("$t"); done < <(recent_tags "$repo")
    [ "${#tags[@]}" -gt 0 ] || { echo "no build images in $repo" >&2; exit 1; }
    echo "Recent builds for $site:"
    for t in "${tags[@]}"; do
      local msg
      msg="$(git -C "$src" log -1 --format='%s (%cr)' "$t" 2>/dev/null || echo '(no local commit)')"
      printf "  %2d) %-10s %s\n" "$i" "$t" "$msg"; i=$((i+1))
    done
    printf "select> "; local pick; read -r pick
    [[ "$pick" =~ ^[0-9]+$ ]] && [ "$pick" -ge 1 ] && [ "$pick" -le "${#tags[@]}" ] \
      || { echo "invalid selection" >&2; exit 1; }
    sha="${tags[$((pick-1))]}"
  fi

  # The tag must exist, or the pin would ImagePullBackOff. Capture stderr (the
  # `2>&1 >/dev/null` order keeps only stderr) and classify it, so a genuine
  # missing tag reads as such while any other AWS failure surfaces verbatim
  # rather than masquerading as one.
  local ecr_err
  if ! ecr_err="$(aws ecr describe-images --repository-name "$repo" --region "$REGION" \
       --image-ids imageTag="$sha" 2>&1 >/dev/null)"; then
    case "$(classify_ecr_error "$ecr_err")" in
      notfound) echo "tag '$sha' not found in ECR repo $repo" >&2 ;;
      *) echo "ECR lookup for '$sha' failed (this is NOT a missing tag):" >&2
         printf '  %s\n' "$ecr_err" >&2 ;;
    esac
    exit 1
  fi

  echo "deploying $site $env -> $sha"
  protect_image "$repo" "$sha" "$env"
  bump_tag "$overlay" "$sha"

  if git -C "$REPO_ROOT" diff --quiet -- "$overlay"; then
    echo "  $site $env already pinned to $sha (image protected); nothing to commit"; exit 0
  fi
  git -C "$REPO_ROOT" add "$overlay"
  git -C "$REPO_ROOT" commit -q \
    -m "deploy($site): $env -> $sha" \
    -m "$(git -C "$src" log -1 --format='%s' "$sha" 2>/dev/null || true)"
  git -C "$REPO_ROOT" push -q origin main
  echo "  pinned + pushed; Argo CD will roll it out."
}

# Only run main when executed, not when sourced (lets the test source bump_tag).
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then main "$@"; fi
